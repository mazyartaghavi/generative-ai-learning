# Fleet Guarded-RAG application settings
#
# Copy this file to .env to override the defaults.
# Do not commit a real .env file containing secrets.

FLEET_API_TITLE=Fleet Guarded-RAG API
FLEET_API_VERSION=1.0.0
FLEET_API_HOST=127.0.0.1
FLEET_API_PORT=8000

FLEET_VECTOR_INDEX_PATH=data/fleet_vector_index.json

FLEET_QDRANT_PATH=data/qdrant_local
FLEET_QDRANT_COLLECTION=fleet_manual_chunks
FLEET_RETRIEVAL_TOP_K=3

FLEET_OLLAMA_BASE_URL=http://127.0.0.1:11434
FLEET_GENERATION_MODEL=llama3.2:3b
FLEET_EMBEDDING_MODEL=embeddinggemma
FLEET_OLLAMA_TIMEOUT_SECONDS=120