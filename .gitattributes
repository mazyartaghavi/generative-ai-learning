# Normalize text files in the Git repository
* text=auto

# Cross-platform project files use Linux line endings
*.py text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.lock text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf
.env.example text eol=lf

# Windows command scripts use Windows line endings
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
